{
  "manifest_version": 3,
  "name": "IOL Salta - Seguimiento de Expedientes",
  "version": "1.0.0",
  "description": "Seguimiento de causas judiciales del Poder Judicial de Salta (Iurix Online). Búsqueda, monitoreo automático y notificaciones de novedades.",
  "author": "Juan Pablo Terraf",
  "homepage_url": "https://derechointeligente.com.ar",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "downloads",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://plataforma.justiciasalta.gov.ar/*",
    "https://generativelanguage.googleapis.com/*",
    "https://notebooklm.google.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://plataforma.justiciasalta.gov.ar/*"],
      "js": ["content/content-script.js"],
      "css": ["content/content-style.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://plataforma.justiciasalta.gov.ar/*"],
      "js": ["content/inject-interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  }
}
